# ── App ─────────────────────────────────────────────
APP_PORT=8000
APP_ENV=development
APP_NAME=SkillsHub
LOG_LEVEL=INFO

# ── Database (Supabase Postgres) ────────────────────
# Use the "Session pooler" URI for long-lived FastAPI workers.
# Format: postgresql+asyncpg://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres.YOURREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
# Sync URL used only by Alembic (psycopg2). Same DB, sync driver.
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.YOURREF:YOURPASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Auth ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ── Supabase ────────────────────────────────────────
SUPABASE_URL=https://YOURREF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=resumes

# ── AI (Google Gemini) ──────────────────────────────
# Free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...
GEMINI_MODEL_SHOWCASE=gemini-2.5-pro
GEMINI_MODEL_LIGHT=gemini-2.5-flash

# ── CORS ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Demo seed accounts ──────────────────────────────
SEED_HR_EMAIL=hr@skillshub.demo
SEED_HR_PASSWORD=demo123
SEED_EMP_EMAIL=ravi@skillshub.demo
SEED_EMP_PASSWORD=demo123
